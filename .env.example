# Zerion API - untuk wallet EVM (Ethereum, Base, Arbitrum, BNB, dll)
# Daftar di https://developers.zerion.io
ZERION_API_KEY=your_zerion_api_key_here

# Helius API - untuk wallet Solana (free 100k req/bulan)
# Daftar di https://helius.dev
HELIUS_API_KEY=your_helius_api_key_here

# Telegram bot - untuk daily snapshot ke channel
# Bikin bot: @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Channel ID: forward 1 message dari channel ke @userinfobot
TELEGRAM_CHAT_ID=-1001234567890

# Vercel KV credentials (auto-injected sama Vercel saat connect KV ke project)
# KV_REST_API_URL, KV_REST_API_TOKEN, dll auto-set via Vercel dashboard

# Optional: protect cron endpoint dari pemanggilan random
# CRON_SECRET=random_secret_string

# Optional: cache TTL in seconds (default 60)
PORTFOLIO_CACHE_TTL=60
