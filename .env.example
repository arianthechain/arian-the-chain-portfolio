# Zerion API - untuk wallet EVM (Ethereum, Base, Arbitrum, BNB, dll)
# Daftar di https://developers.zerion.io
ZERION_API_KEY=your_zerion_api_key_here

# Helius API - untuk wallet Solana (free 100k req/bulan)
# Daftar di https://helius.dev
HELIUS_API_KEY=your_helius_api_key_here

# Optional: cache TTL in seconds (default 60)
PORTFOLIO_CACHE_TTL=60
